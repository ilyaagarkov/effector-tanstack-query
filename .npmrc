# Local development: prefer workspace packages over the npm registry when a
# version matches, so the examples (which declare `^0.1.1` to demonstrate the
# real npm package version to readers) get linked to the in-tree packages
# during `pnpm install`. Without this, pnpm 10 defaults to `false` and tries
# to fetch from registry.
link-workspace-packages=true
prefer-workspace-packages=true
