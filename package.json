{
  "name": "effector-tanstack-query-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @effector-tanstack-query/* packages",
  "license": "MIT",
  "author": "Ilya Agarkov <ilya.al.ag@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilyaagarkov/effector-tanstack-query.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "clean": "pnpm -r --filter './packages/*' run clean && rm -rf node_modules",
    "test": "pnpm -r --filter './packages/*' run test",
    "test:types": "pnpm -r --filter './packages/*' run test:types",
    "release": "pnpm build && pnpm -r --filter './packages/*' publish --access public --no-git-checks --provenance"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-istanbul": "^4.0.6",
    "effector": "^23.4.4",
    "effector-react": "^23.3.0",
    "esbuild-plugin-file-path-extensions": "^2.1.4",
    "jsdom": "^27.4.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
